PORT=8080
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority&appName=Cluster0
JWT_SECRET=your-secret-key-here
CORS_ORIGIN=http://localhost:5173,https://example.com

# Admin inicial (criado automaticamente ao subir a API)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=SecurePassword123

# SMTP para envio de emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# R2/S3 Configuration (opcional)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket
R2_PUBLIC_URL=https://your-public-url.com
